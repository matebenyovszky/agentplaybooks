{
  "name": "agentplaybooks",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "AgentPlaybooks",
  "scripts": {
    "dev": "next dev",
    "prebuild": "tsx scripts/generate-blog-slugs.ts",
    "build": "next build",
    "postbuild:worker": "tsx scripts/copy-markdown-assets.ts",
    "start": "next start",
    "lint": "eslint",
    "sync-sitemap": "tsx scripts/sync-sitemap-docs.ts",
    "build:worker": "npm run prebuild && opennextjs-cloudflare build && npm run postbuild:worker",
    "dev:worker": "opennextjs-cloudflare dev",
    "preview": "opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv",
    "seed": "tsx scripts/seed-data.ts",
    "seed:skills": "tsx scripts/github-skill-parser.ts",
    "seed:dry": "DRY_RUN=true tsx scripts/seed-data.ts",
    "test": "vitest",
    "test:cli": "npm --prefix packages/cli test",
    "test:all": "vitest run && npm run test:cli",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "15.5.20",
    "@opennextjs/cloudflare": "1.20.1",
    "@supabase/supabase-js": "^2.89.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.23.26",
    "hono": "4.12.31",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "next": "15.5.20",
    "next-intl": "4.13.2",
    "pg": "^8.22.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.20.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260719.1",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@swc/helpers": "^0.5.18",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.7.0",
    "typescript": "^5",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
